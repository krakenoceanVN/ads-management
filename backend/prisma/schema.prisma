generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// TABLE 1: ad_type
// ============================================================
model AdType {
  id        String   @id  // 6-char alphanumeric, generated app-side (also used as FK identifier)
  name      String
  upstreamId String?  // Nhà QC sở hữu đơn này (mục 1.2)
  notes     String?
  status    String    @default("active") // active | inactive
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  owner      Upstream? @relation("AdTypeOwner", fields: [upstreamId], references: [id])
  upstreamAdTypes    UpstreamAdType[]
  downstreamAdTypes  DownstreamAdType[]
  mediaOrders        MediaAdOrder[]
  adSiteDownstreams  AdSiteDownstream[]   // relation via mediaAdTypeId
  defaultForUpstreams Upstream[] @relation("UpstreamDefaultAdType")
  adSites            AdSite[]   @relation("AdSiteAdType")

  @@index([upstreamId])
  @@index([status])
}

// ============================================================
// TABLE 5b: downstream_ad_type (junction, mirrors UpstreamAdType)
// ============================================================
model DownstreamAdType {
  id           String   @id
  downstreamId String
  adTypeId     String
  createdAt    DateTime @default(now())

  downstream Downstream @relation(fields: [downstreamId], references: [id], onDelete: Cascade)
  adType     AdType     @relation(fields: [adTypeId], references: [id])

  @@unique([downstreamId, adTypeId])
  @@index([downstreamId])
  @@index([adTypeId])
}

// ============================================================
// TABLE 2: upstream
// ============================================================
model Upstream {
  id        String   @id
  adTypeId  String?
  name      String
  status    String    @default("active") // active | inactive
  contact   String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  defaultAdType AdType?          @relation("UpstreamDefaultAdType", fields: [adTypeId], references: [id])
  adTypeLinks UpstreamAdType[]
  adSites     AdSite[]
  ownedAdTypes AdType[]         @relation("AdTypeOwner")

  @@index([adTypeId])
  @@index([adTypeId, status])
}

model UpstreamAdType {
  id         String   @id
  upstreamId String
  adTypeId   String
  createdAt  DateTime  @default(now())

  upstream   Upstream @relation(fields: [upstreamId], references: [id], onDelete: Cascade)
  adType     AdType   @relation(fields: [adTypeId], references: [id])

  @@unique([upstreamId, adTypeId])
  @@index([upstreamId])
  @@index([adTypeId])
}

// ============================================================
// TABLE 2c: media_ad_order (per-Downstream ad order)
// Scoped to Downstream (a.k.a. "Hạ nguồn / Media" in UI).
// ============================================================
model MediaAdOrder {
  id           String   @id
  downstreamId String
  adTypeId     String?
  seq          Int
  name         String
  notes        String?
  status       String    @default("active") // active | inactive
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  downstream Downstream @relation(fields: [downstreamId], references: [id])
  adType     AdType?    @relation(fields: [adTypeId], references: [id])
  mediaIds   AdSiteDownstream[]

  @@unique([downstreamId, seq])
  @@index([downstreamId])
  @@index([adTypeId])
  @@index([status])
}

model AdSiteRebateRate {
  id        String   @id @default(uuid())
  adSiteId  String
  rate      Decimal
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adSite AdSite @relation(fields: [adSiteId], references: [id], onDelete: Cascade)

  @@index([adSiteId, startDate])
  @@index([adSiteId, endDate])
}

// ============================================================
// TABLE 3: ad_site
// ============================================================
model AdSite {
  id               String   @id
  upstreamId       String
  name             String
  notes            String?
  billingMethod    String    // CPM | CPC | CPS | CPA
  rebateRate       Float?
  currentUnitPrice Decimal?  // for CPM/CPC/CPA
  currentRatio    Decimal?  // for CPS
  isActive         Boolean   @default(true)
  isArchived       Boolean   @default(false)
  status           String    @default("active") // active | inactive
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  adTypeId         String?

  upstream Upstream        @relation(fields: [upstreamId], references: [id])
  adType   AdType?         @relation("AdSiteAdType", fields: [adTypeId], references: [id], onDelete: SetNull)
  dailyInputs DailyInput[]
  downstreams AdSiteDownstream[]
  events         AdSiteEvent[]
  rebateRates    AdSiteRebateRate[]

  @@index([upstreamId])
  @@index([adTypeId])
  @@index([isActive])
  @@index([isArchived])
  @@index([upstreamId, isActive, isArchived])
}

model AdSiteEvent {
  id        String   @id @default(uuid())
  adSiteId  String
  eventType String
  note      String?
  eventDate DateTime @default(now())
  createdAt DateTime @default(now())

  adSite AdSite @relation(fields: [adSiteId], references: [id], onDelete: Cascade)

  @@index([adSiteId, eventDate, createdAt])
}

// ============================================================
// TABLE 3b: ad_site_downstream (junction)
// ============================================================
model AdSiteDownstream {
  id                String   @id
  adSiteId          String
  downstreamId      String
  mediaAdOrderId    String?   // FK tới MediaAdOrder — đơn QC media mà MediaId này thuộc về
  customPrice       Decimal?  // giá tự điền cho hạ nguồn
  pctHal            Decimal?  // tỷ lệ chia riêng cho cặp (AdSite, Downstream); null = dùng DownstreamPeriod.pctHal
  notes             String?   // ghi chú cho từng junction (mục 2.3)
  mediaAdTypeId     String?   // FK tới AdType — đơn QC ở MEDIA side
  mediaIdName       String?   // ID media (tên do người dùng tự đặt)
  status            String    @default("active") // active | inactive

  adSite     AdSite     @relation(fields: [adSiteId], references: [id], onDelete: Cascade)
  downstream Downstream @relation(fields: [downstreamId], references: [id], onDelete: Cascade)
  mediaAdType AdType?   @relation(fields: [mediaAdTypeId], references: [id], onDelete: SetNull)
  mediaAdOrder MediaAdOrder? @relation(fields: [mediaAdOrderId], references: [id], onDelete: SetNull)

  @@unique([adSiteId, downstreamId])
  @@index([adSiteId])
  @@index([downstreamId])
  @@index([mediaAdTypeId])
  @@index([mediaAdOrderId])
}

// ============================================================
// TABLE 4: daily_input
// ============================================================
model DailyInput {
  id                 String   @id
  recordDate         DateTime
  adSiteId           String
  qty                Int       @default(0)           // CPM quantity
  unitPriceSnapshot  Decimal?                       // CPM price snapshot
  amount1            Decimal   @default(0)          // CPS amount1
  amount2            Decimal   @default(0)          // CPS amount2
  ratioSnapshot      Decimal?                       // CPS ratio snapshot
  rebateAmount       Decimal   @default(0)
  rebateRateSnapshot Decimal   @default(0)
  revenue            Decimal   @default(0)
  status             String    @default("unconfirmed") // unconfirmed | confirmed | quarantined
  note               String?
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // quarantine fields
  quarantineBatchId  String?
  quarantinedAt      DateTime?
  quarantinedBy      String?
  quarantineReason   String?

  adSite             AdSite                    @relation(fields: [adSiteId], references: [id])
  quarantineBatch    DailyInputQuarantineBatch? @relation("DailyInputActiveQuarantineBatch", fields: [quarantineBatchId], references: [id])
  quarantineRecords  DailyInputQuarantineRecord[]

  @@unique([recordDate, adSiteId])
  @@index([recordDate])
  @@index([adSiteId])
  @@index([status])
  @@index([status, recordDate, adSiteId])
  @@index([quarantineBatchId])
  @@index([status, quarantineBatchId])
}

// ============================================================
// TABLE 4b: daily_input_quarantine_batch
// ============================================================
model DailyInputQuarantineBatch {
  id           String   @id
  scopeType    String    // advertiser | media
  advertiserId String?
  adSiteId     String?
  startDate    DateTime
  endDate      DateTime
  reason       String?
  recordCount  Int       @default(0)
  totalRevenue Decimal   @default(0)
  createdBy    String?
  createdAt    DateTime  @default(now())
  restoredAt   DateTime?
  restoredBy   String?

  activeRecords DailyInput[]                 @relation("DailyInputActiveQuarantineBatch")
  records       DailyInputQuarantineRecord[]

  @@index([advertiserId])
  @@index([adSiteId])
  @@index([restoredAt])
}

// ============================================================
// TABLE 4c: daily_input_quarantine_record
// ============================================================
model DailyInputQuarantineRecord {
  id              String   @id
  batchId         String
  dailyInputId    String
  statusBefore    String   // "confirmed" at time of quarantine
  revenueSnapshot Decimal

  batch     DailyInputQuarantineBatch @relation(fields: [batchId], references: [id])
  dailyInput DailyInput               @relation(fields: [dailyInputId], references: [id])

  @@unique([batchId, dailyInputId])
  @@index([batchId])
  @@index([dailyInputId])
}

// ============================================================
// TABLE 5: downstream
// ============================================================
model Downstream {
  id              String   @id
  downstreamType  String    // ML | LE | YIYI
  name            String?
  contact         String?
  phone           String?
  email           String?
  notes           String?
  status          String    @default("active") // active | inactive
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  adTypeLinks DownstreamAdType[]
  periods  DownstreamPeriod[]
  dailyRates DailyDownstreamRate[]
  adSites  AdSiteDownstream[]
  mediaAdOrders MediaAdOrder[]
}

// ============================================================
// TABLE 6: downstream_period
// ============================================================
model DownstreamPeriod {
  id            String   @id
  downstreamId  String
  pctHal        Decimal    @default(1.0)  // tỷ lệ UV tính ML
  unitPrice     Decimal?               // đơn giá payout
  startDate     DateTime
  endDate       DateTime?             // NULL = đang hiệu lực
  note          String?
  createdBy     String?
  createdAt     DateTime  @default(now())

  downstream  Downstream  @relation(fields: [downstreamId], references: [id], onDelete: Cascade)

  @@index([downstreamId, startDate])
}

// ============================================================
// TABLE 6b: daily_downstream_rate
// ============================================================
model DailyDownstreamRate {
  id            String   @id
  downstreamId  String
  date          DateTime
  effectiveRate Decimal

  downstream  Downstream  @relation(fields: [downstreamId], references: [id], onDelete: Cascade)

  @@unique([downstreamId, date])
  @@index([downstreamId])
  @@index([date])
}

// ============================================================
// TABLE 7: user
// ============================================================
model User {
  id               String   @id
  username         String    @unique
  passwordHash     String
  role             String    @default("EDITOR") // ADMIN | EDITOR | VIEWER | MANAGER | SUPER_ADMIN
  permDataInput    Boolean   @default(false)
  permDataConfirm  Boolean   @default(false)
  permAdmin        Boolean   @default(false)
  status           String    @default("active") // active | inactive
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  roleId           String?
  roleRef         Role?     @relation("UserRoleRef", fields: [roleId], references: [id])
}

// ============================================================
// TABLE 7b: role
// ============================================================
model Role {
  id          String   @id
  code        String    @unique
  name        String
  description String?
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]    @relation("UserRoleRef")
  permissions RolePermission[]
}

// ============================================================
// TABLE 7c: permission
// ============================================================
model Permission {
  id          String   @id
  key         String    @unique
  module      String
  action      String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  roles       RolePermission[]
}

// ============================================================
// TABLE 7d: role_permission
// ============================================================
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ============================================================
// TABLE 8: yiyi_daily_data
// ============================================================
model YiyiDailyData {
  id         String   @id
  recordDate DateTime
  channel    String   // yy-02-01 | yy-02-02 | yy-02-03 | yy-02-04
  qty        Int
  createdAt  DateTime @default(now())

  @@unique([recordDate, channel])
}

model YiyiDailyPricing {
  id              String   @id
  recordDate      DateTime @unique
  unitPrice       Decimal  @default(2)
  profitUnitPrice Decimal  @default(1)
  updatedAt       DateTime @updatedAt
}

// ============================================================
// TABLE 9: le_daily_cost
// ============================================================
model LEDailyCost {
  id         String   @id
  recordDate DateTime @unique
  vendorCost Decimal  @default(0)
  mlCost     Decimal  @default(0)
  costAmount Decimal  @default(0)
  updatedAt  DateTime @updatedAt
}

// ============================================================
// TABLE 10: operation_log
// ============================================================
model OperationLog {
  id         String   @id
  userId     String?
  username   String?
  action     String
  module     String
  targetType String?
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([module])
  @@index([action])
  @@index([userId])
}