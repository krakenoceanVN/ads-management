generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// TABLE 1: ad_type
// ============================================================
model AdType {
  id        Int       @id
  code      String    @unique // SM | 360 | BAIDU_JS
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  upstreams       Upstream[]
  upstreamAdTypes UpstreamAdType[]
  downstreamAdTypes DownstreamAdType[]
  orders          AdOrder[]
}

// ============================================================
// TABLE 5b: downstream_ad_type (junction, mirrors UpstreamAdType)
// ============================================================
model DownstreamAdType {
  id           Int      @id @default(autoincrement())
  downstreamId Int
  adTypeId     Int
  createdAt    DateTime @default(now())

  downstream Downstream @relation(fields: [downstreamId], references: [id], onDelete: Cascade)
  adType     AdType     @relation(fields: [adTypeId], references: [id])

  @@unique([downstreamId, adTypeId])
  @@index([downstreamId])
  @@index([adTypeId])
}

// ============================================================
// TABLE 2: upstream
// ============================================================
model Upstream {
  id        Int       @id @default(autoincrement())
  adTypeId  Int
  name      String
  status    String    @default("active") // active | inactive
  contact   String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  adType      AdType           @relation(fields: [adTypeId], references: [id])
  adTypeLinks UpstreamAdType[]
  adSites     AdSite[]
  adOrders    AdOrder[]

  @@index([adTypeId])
  @@index([adTypeId, status])
}

model UpstreamAdType {
  id         Int      @id @default(autoincrement())
  upstreamId Int
  adTypeId   Int
  createdAt  DateTime @default(now())

  upstream   Upstream @relation(fields: [upstreamId], references: [id], onDelete: Cascade)
  adType     AdType   @relation(fields: [adTypeId], references: [id])

  @@unique([upstreamId, adTypeId])
  @@index([upstreamId])
  @@index([adTypeId])
}

// ============================================================
// TABLE 2b: ad_order (per-advertiser order/campaign)
// ============================================================
model AdOrder {
  id         Int       @id @default(autoincrement())
  upstreamId Int
  adTypeId   Int
  name       String
  notes      String?
  status     String    @default("active") // active | inactive
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  upstream Upstream @relation(fields: [upstreamId], references: [id])
  adType   AdType   @relation(fields: [adTypeId], references: [id])
  adSites  AdSite[]

  @@index([upstreamId])
  @@index([adTypeId])
  @@index([status])
}

model AdSiteRebateRate {
  id        String   @id @default(uuid())
  adSiteId  Int
  rate      Decimal
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adSite AdSite @relation(fields: [adSiteId], references: [id], onDelete: Cascade)

  @@index([adSiteId, startDate])
  @@index([adSiteId, endDate])
}

// ============================================================
// TABLE 3: ad_site
// ============================================================
model AdSite {
  id               Int       @id @default(autoincrement())
  upstreamId       Int
  adOrderId        Int?
  name             String
  notes            String?
  billingMethod    String    // CPM | RATIO | CPA
  rebateRate       Float?
  currentUnitPrice Decimal?  // for CPM
  currentRatio    Decimal?  // for RATIO
  isActive         Boolean   @default(true)
  isArchived       Boolean   @default(false)
  status           String    @default("active") // active | inactive
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  upstream Upstream        @relation(fields: [upstreamId], references: [id])
  adOrder  AdOrder?        @relation(fields: [adOrderId], references: [id])
  dailyInputs DailyInput[]
  downstreams AdSiteDownstream[]
  events         AdSiteEvent[]
  rebateRates    AdSiteRebateRate[]

  @@index([upstreamId])
  @@index([isActive])
  @@index([isArchived])
  @@index([upstreamId, isActive, isArchived])
}

model AdSiteEvent {
  id        String   @id @default(uuid())
  adSiteId  Int
  eventType String
  note      String?
  eventDate DateTime @default(now())
  createdAt DateTime @default(now())

  adSite AdSite @relation(fields: [adSiteId], references: [id], onDelete: Cascade)

  @@index([adSiteId, eventDate, createdAt])
}

// ============================================================
// TABLE 3b: ad_site_downstream (junction)
// ============================================================
model AdSiteDownstream {
  id           Int     @id @default(autoincrement())
  adSiteId     Int
  downstreamId Int
  customPrice  Decimal?  // giá tự điền cho hạ nguồn

  adSite     AdSite     @relation(fields: [adSiteId], references: [id], onDelete: Cascade)
  downstream Downstream @relation(fields: [downstreamId], references: [id], onDelete: Cascade)

  @@unique([adSiteId, downstreamId])
  @@index([adSiteId])
  @@index([downstreamId])
}

// ============================================================
// TABLE 4: daily_input
// ============================================================
model DailyInput {
  id                 Int       @id @default(autoincrement())
  recordDate         DateTime
  adSiteId           Int
  qty                Int       @default(0)           // CPM quantity
  unitPriceSnapshot  Decimal?                       // CPM price snapshot
  amount1            Decimal   @default(0)          // RATIO amount1
  amount2            Decimal   @default(0)          // RATIO amount2
  ratioSnapshot      Decimal?                       // RATIO ratio snapshot
  rebateAmount       Decimal   @default(0)
  rebateRateSnapshot Decimal   @default(0)
  revenue            Decimal   @default(0)
  status             String    @default("unconfirmed") // unconfirmed | confirmed | quarantined
  note               String?
  createdBy          Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // quarantine fields
  quarantineBatchId  Int?
  quarantinedAt      DateTime?
  quarantinedBy      Int?
  quarantineReason   String?

  adSite             AdSite                    @relation(fields: [adSiteId], references: [id])
  quarantineBatch    DailyInputQuarantineBatch? @relation("DailyInputActiveQuarantineBatch", fields: [quarantineBatchId], references: [id])
  quarantineRecords  DailyInputQuarantineRecord[]

  @@unique([recordDate, adSiteId])
  @@index([recordDate])
  @@index([adSiteId])
  @@index([status])
  @@index([status, recordDate, adSiteId])
  @@index([quarantineBatchId])
  @@index([status, quarantineBatchId])
}

// ============================================================
// TABLE 4b: daily_input_quarantine_batch
// ============================================================
model DailyInputQuarantineBatch {
  id           Int       @id @default(autoincrement())
  scopeType    String    // advertiser | media
  advertiserId Int?
  adSiteId     Int?
  startDate    DateTime
  endDate      DateTime
  reason       String?
  recordCount  Int       @default(0)
  totalRevenue Decimal   @default(0)
  createdBy    Int?
  createdAt    DateTime  @default(now())
  restoredAt   DateTime?
  restoredBy   Int?

  activeRecords DailyInput[]                 @relation("DailyInputActiveQuarantineBatch")
  records       DailyInputQuarantineRecord[]

  @@index([advertiserId])
  @@index([adSiteId])
  @@index([restoredAt])
}

// ============================================================
// TABLE 4c: daily_input_quarantine_record
// ============================================================
model DailyInputQuarantineRecord {
  id              Int      @id @default(autoincrement())
  batchId         Int
  dailyInputId    Int
  statusBefore    String   // "confirmed" at time of quarantine
  revenueSnapshot Decimal

  batch     DailyInputQuarantineBatch @relation(fields: [batchId], references: [id])
  dailyInput DailyInput               @relation(fields: [dailyInputId], references: [id])

  @@unique([batchId, dailyInputId])
  @@index([batchId])
  @@index([dailyInputId])
}

// ============================================================
// TABLE 5: downstream
// ============================================================
model Downstream {
  id              Int       @id @default(autoincrement())
  downstreamType  String    // ML | LE | YIYI
  payoutRate      Decimal   @default(0.8)
  status          String    @default("active") // active | inactive
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  adTypeLinks DownstreamAdType[]
  periods  DownstreamPeriod[]
  dailyRates DailyDownstreamRate[]
  adSites  AdSiteDownstream[]
}

// ============================================================
// TABLE 6: downstream_period
// ============================================================
model DownstreamPeriod {
  id            Int        @id @default(autoincrement())
  downstreamId  Int
  pctHal        Decimal    @default(1.0)  // tỷ lệ UV tính ML
  unitPrice     Decimal?               // đơn giá payout
  startDate     DateTime
  endDate       DateTime?             // NULL = đang hiệu lực
  note          String?
  createdBy     Int?
  createdAt     DateTime  @default(now())

  downstream  Downstream  @relation(fields: [downstreamId], references: [id], onDelete: Cascade)

  @@index([downstreamId, startDate])
}

// ============================================================
// TABLE 6b: daily_downstream_rate
// ============================================================
model DailyDownstreamRate {
  id            Int      @id @default(autoincrement())
  downstreamId  Int
  date          DateTime
  effectiveRate Decimal

  downstream  Downstream  @relation(fields: [downstreamId], references: [id], onDelete: Cascade)

  @@unique([downstreamId, date])
  @@index([downstreamId])
  @@index([date])
}

// ============================================================
// TABLE 7: user
// ============================================================
model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique
  passwordHash     String
  role             String    @default("EDITOR") // ADMIN | EDITOR | VIEWER | MANAGER | SUPER_ADMIN
  permDataInput    Boolean   @default(false)
  permDataConfirm  Boolean   @default(false)
  permAdmin        Boolean   @default(false)
  status           String    @default("active") // active | inactive
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  roleId           Int?
  roleRef         Role?     @relation("UserRoleRef", fields: [roleId], references: [id])
}

// ============================================================
// TABLE 7b: role
// ============================================================
model Role {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  name        String
  description String?
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]    @relation("UserRoleRef")
  permissions RolePermission[]
}

// ============================================================
// TABLE 7c: permission
// ============================================================
model Permission {
  id          Int       @id @default(autoincrement())
  key         String    @unique
  module      String
  action      String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  roles       RolePermission[]
}

// ============================================================
// TABLE 7d: role_permission
// ============================================================
model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ============================================================
// TABLE 8: yiyi_daily_data
// ============================================================
model YiyiDailyData {
  id         Int      @id @default(autoincrement())
  recordDate DateTime
  channel    String   // yy-02-01 | yy-02-02 | yy-02-03 | yy-02-04
  qty        Int
  createdAt  DateTime @default(now())

  @@unique([recordDate, channel])
}

model YiyiDailyPricing {
  id              Int      @id @default(autoincrement())
  recordDate      DateTime @unique
  unitPrice       Decimal  @default(2)
  profitUnitPrice Decimal  @default(1)
  updatedAt       DateTime @updatedAt
}

// ============================================================
// TABLE 9: le_daily_cost
// ============================================================
model LEDailyCost {
  id         Int      @id @default(autoincrement())
  recordDate DateTime @unique
  vendorCost Decimal  @default(0)
  mlCost     Decimal  @default(0)
  costAmount Decimal  @default(0)
  updatedAt  DateTime @updatedAt
}

// ============================================================
// TABLE 10: operation_log
// ============================================================
model OperationLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  username   String?
  action     String
  module     String
  targetType String?
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([module])
  @@index([action])
  @@index([userId])
}
