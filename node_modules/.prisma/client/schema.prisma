generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// TABLE 1: ad_type
// ============================================================
model AdType {
  id        Int      @id
  code      String   @unique // SM | 360 | BAIDU_JS
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upstreams   Upstream[]
  downstreams Downstream[]
}

// ============================================================
// TABLE 2: upstream
// ============================================================
model Upstream {
  id        Int      @id @default(autoincrement())
  adTypeId  Int
  name      String
  status    String   @default("active") // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adType  AdType   @relation(fields: [adTypeId], references: [id])
  adSites AdSite[]

  @@index([adTypeId])
  @@index([adTypeId, status])
}

// ============================================================
// TABLE 3: ad_site
// ============================================================
model AdSite {
  id               Int      @id @default(autoincrement())
  upstreamId       Int
  name             String
  billingMethod    String // CPM | RATIO | CPA
  rebateRate       Float?
  currentUnitPrice Decimal? // for CPM
  currentRatio     Decimal? // for RATIO
  isActive         Boolean  @default(true)
  isArchived       Boolean  @default(false)
  status           String   @default("active") // active | inactive
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  upstream    Upstream           @relation(fields: [upstreamId], references: [id])
  dailyInputs DailyInput[]
  downstreams AdSiteDownstream[]
  events      AdSiteEvent[]

  @@index([upstreamId])
  @@index([isActive])
  @@index([isArchived])
  @@index([upstreamId, isActive, isArchived])
}

model AdSiteEvent {
  id        String   @id @default(uuid())
  adSiteId  Int
  eventType String
  note      String?
  eventDate DateTime @default(now())
  createdAt DateTime @default(now())

  adSite AdSite @relation(fields: [adSiteId], references: [id], onDelete: Cascade)

  @@index([adSiteId, eventDate, createdAt])
}

// ============================================================
// TABLE 3b: ad_site_downstream (junction)
// ============================================================
model AdSiteDownstream {
  id           Int      @id @default(autoincrement())
  adSiteId     Int
  downstreamId Int
  customPrice  Decimal? // giá tự điền cho hạ nguồn

  adSite     AdSite     @relation(fields: [adSiteId], references: [id], onDelete: Cascade)
  downstream Downstream @relation(fields: [downstreamId], references: [id], onDelete: Cascade)

  @@unique([adSiteId, downstreamId])
  @@index([adSiteId])
  @@index([downstreamId])
}

// ============================================================
// TABLE 4: daily_input
// ============================================================
model DailyInput {
  id                Int      @id @default(autoincrement())
  recordDate        DateTime
  adSiteId          Int
  qty               Int      @default(0) // CPM quantity
  unitPriceSnapshot Decimal? // CPM price snapshot
  amount1           Decimal  @default(0) // RATIO amount1
  amount2           Decimal  @default(0) // RATIO amount2
  ratioSnapshot     Decimal? // RATIO ratio snapshot
  revenue           Decimal  @default(0)
  status            String   @default("unconfirmed") // unconfirmed | confirmed
  note              String?
  createdBy         Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  adSite AdSite @relation(fields: [adSiteId], references: [id])

  @@unique([recordDate, adSiteId])
  @@index([recordDate])
  @@index([adSiteId])
  @@index([status])
  @@index([status, recordDate, adSiteId])
}

// ============================================================
// TABLE 5: downstream
// ============================================================
model Downstream {
  id             Int      @id @default(autoincrement())
  adTypeId       Int
  downstreamType String // ML | LE | YIYI
  payoutRate     Decimal  @default(0.8)
  status         String   @default("active") // active | inactive
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  adType     AdType                @relation(fields: [adTypeId], references: [id])
  periods    DownstreamPeriod[]
  dailyRates DailyDownstreamRate[]
  adSites    AdSiteDownstream[]

  @@index([adTypeId])
}

// ============================================================
// TABLE 6: downstream_period
// ============================================================
model DownstreamPeriod {
  id           Int       @id @default(autoincrement())
  downstreamId Int
  pctHal       Decimal   @default(1.0) // tỷ lệ UV tính ML
  unitPrice    Decimal? // đơn giá payout
  startDate    DateTime
  endDate      DateTime? // NULL = đang hiệu lực
  note         String?
  createdBy    Int?
  createdAt    DateTime  @default(now())

  downstream Downstream @relation(fields: [downstreamId], references: [id], onDelete: Cascade)

  @@index([downstreamId, startDate])
}

// ============================================================
// TABLE 6b: daily_downstream_rate
// ============================================================
model DailyDownstreamRate {
  id            Int      @id @default(autoincrement())
  downstreamId  Int
  date          DateTime
  effectiveRate Decimal

  downstream Downstream @relation(fields: [downstreamId], references: [id], onDelete: Cascade)

  @@unique([downstreamId, date])
  @@index([downstreamId])
  @@index([date])
}

// ============================================================
// TABLE 7: user
// ============================================================
model User {
  id              Int       @id @default(autoincrement())
  username        String    @unique
  passwordHash    String
  role            String    @default("EDITOR") // ADMIN | EDITOR | VIEWER
  permDataInput   Boolean   @default(false)
  permDataConfirm Boolean   @default(false)
  permAdmin       Boolean   @default(false)
  status          String    @default("active") // active | inactive
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
}

// ============================================================
// TABLE 8: yiyi_daily_data
// ============================================================
model YiyiDailyData {
  id         Int      @id @default(autoincrement())
  recordDate DateTime
  channel    String // yy-02-01 | yy-02-02 | yy-02-03 | yy-02-04
  qty        Int
  createdAt  DateTime @default(now())

  @@unique([recordDate, channel])
}

model YiyiDailyPricing {
  id              Int      @id @default(autoincrement())
  recordDate      DateTime @unique
  unitPrice       Decimal  @default(2)
  profitUnitPrice Decimal  @default(1)
  updatedAt       DateTime @updatedAt
}

// ============================================================
// TABLE 9: le_daily_cost
// ============================================================
model LEDailyCost {
  id         Int      @id @default(autoincrement())
  recordDate DateTime @unique
  vendorCost Decimal  @default(0)
  mlCost     Decimal  @default(0)
  costAmount Decimal  @default(0)
  updatedAt  DateTime @updatedAt
}
